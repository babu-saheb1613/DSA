class Solution {
public:
void getprintSubset(vector<int>& nums,vector<int> ans ,int i,vector<vector<int>> &subsets) {
    if(i==nums.size()) {
        subsets.push_back({ans});
        return;
    }
    ans.push_back(nums[i]);
    getprintSubset(nums,ans,i+1,subsets);
    ans.pop_back();
     getprintSubset(nums,ans,i+1,subsets);

}
    vector<vector<int>> subsets(vector<int>& nums) {
         vector<vector<int>> subsets;
         vector<int> ans;
          getprintSubset(nums,ans,0,subsets);
          return subsets; 


        
    }
};